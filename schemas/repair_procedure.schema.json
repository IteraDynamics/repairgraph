{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RepairGraph Repair Procedure",
  "type": "object",
  "required": [
    "oem",
    "year",
    "model",
    "operation",
    "operation_family"
  ],
  "properties": {
    "oem": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "model": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "operation_family": {
      "type": "string"
    },
    "joining_methods": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        }
      }
    },
    "repair_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
